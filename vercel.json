{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/trpc.js": {
      "maxDuration": 30,
      "includeFiles": "api/package.json"
    }
  },
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/trpc" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
